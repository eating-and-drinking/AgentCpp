# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=your-api-key-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Model to use (default: claude-opus-4-5)
# CLAUDE_MODEL=claude-sonnet-4-5

# Custom API base URL — for OpenRouter, MiniMax, or local proxies
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1

# API version header (default: 2023-06-01)
# ANTHROPIC_API_VERSION=2023-06-01

# Maximum output tokens per turn (default: 8096)
# CLAUDE_MAX_TOKENS=8096

# Enable debug logging (default: false)
# CLAUDE_DEBUG=1

# Force headless mode (default: false)
# CLAUDE_HEADLESS=1
